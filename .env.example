# Base de datos PostgreSQL
POSTGRES_DB=wot_db
POSTGRES_USER=wot_user
POSTGRES_PASSWORD=           # Genera con: openssl rand -hex 12

# JWT
JWT_SECRET=                  # Genera con: openssl rand -hex 32
JWT_EXPIRES_IN=8h

# DigitalOcean Spaces — Space: catalogo-imagenes-api (NYC3)
DO_SPACES_KEY=               # Obtener en: DigitalOcean → API → Spaces Keys
DO_SPACES_SECRET=            # Solo visible al generar la key, cópiala inmediatamente
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
DO_SPACES_BUCKET=catalogo-imagenes-api
DO_SPACES_CDN_URL=https://catalogo-imagenes-api.nyc3.cdn.digitaloceanspaces.com

# URL del frontend (para CORS del backend)
FRONTEND_URL=http://161.35.2.202   # Cambiar por https://tu-dominio.com cuando tengas dominio
