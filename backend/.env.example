# Variables de entorno — WOT Backend

# Base de datos PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/wot_db?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# DigitalOcean Spaces (S3-compatible)
DO_SPACES_KEY=""
DO_SPACES_SECRET=""
DO_SPACES_ENDPOINT="https://nyc3.digitaloceanspaces.com"
DO_SPACES_BUCKET="wot-bucket"
DO_SPACES_CDN_URL="https://wot-bucket.nyc3.cdn.digitaloceanspaces.com"

# Puerto del servidor (opcional, default 3000)
PORT=3000

# URL del frontend (CORS)
FRONTEND_URL="http://localhost:4200"
